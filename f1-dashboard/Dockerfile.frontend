FROM node:20-slim

WORKDIR /app

# Copy package.json and package-lock.json
COPY package.json package-lock.json ./

# Install dependencies
RUN npm install

# Copy application code
COPY . .

# Expose port for Vite
EXPOSE 5173

# Command to run Vite in dev mode
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
